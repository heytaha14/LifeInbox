# Public browser configuration - safe to expose
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=lifeinbox
NEXT_PUBLIC_APPWRITE_CAPTURES_COLLECTION_ID=captures
NEXT_PUBLIC_APPWRITE_ACTIONS_COLLECTION_ID=actions
NEXT_PUBLIC_APPWRITE_THREADS_COLLECTION_ID=threads
NEXT_PUBLIC_APPWRITE_BRIEFINGS_COLLECTION_ID=briefings
NEXT_PUBLIC_APPWRITE_USAGE_COLLECTION_ID=usage
NEXT_PUBLIC_APPWRITE_BUCKET_ID=inbox-files
NEXT_PUBLIC_APPWRITE_AI_FUNCTION_ID=ai-orchestrator
NEXT_PUBLIC_APPWRITE_OPS_FUNCTION_ID=ops

# Local bootstrap only; never use a NEXT_PUBLIC prefix
APPWRITE_API_KEY=

# Appwrite Function environment variables; never website variables
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPS_SECRET=
FREE_DAILY_CAPTURE_LIMIT=50
FREE_DAILY_AI_TOKEN_LIMIT=250000
FILE_RETENTION_DAYS=30
